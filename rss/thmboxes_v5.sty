\tcbset{
    thmboxstyle/.style n args={6}{
    % general settings
        sharp corners, % sharp corners (box)
    % title box setup
        coltitle=black, 
        attach boxed title to top left={ % position the title box
            yshift=-4pt, % shift down the box
            yshifttext=-1ex, % offset text
        	xshift=7pt}, % shift to the right
        	boxed title style={ % style the title box
            left=0pt, right=0pt, % no margins on left and right side
            sharp corners, % sharp corners (title)
            top = -2.5pt,
            bottom = -2.5pt
        },
    % Title text setup
        fonttitle=\bfseries,
    % Frame setup
        boxrule=0.4pt, % Width of box frame
    % Box setup
        left=0.5pt,
        right=0.5pt,
        top = 0.5pt,
        bottom=0pt, % Bottom padding
        %breakable,
        lines before break=10, % idk how this affects stuff
        break at=-\baselineskip/0pt,
        halign=flush left,
        skin=enhanced,
        colbacktitle=#5, colframe=#5, colback=#6,
    % Lines
        segmentation style={solid, line width=0.3pt, color=black},
        middle=1pt,
    % Other
        label is label,
        title=#1: #3, %Title formatting without numbering
        %title=#1 #2: #3, % Title formatting with numbering
        label=#4,
        subtitle style = {
            bottom = 0.5pt,
            boxsep=0.5pt,
            boxrule=0pt,
        }
    },
% Side by side - No Border No Frame
    sbsstyle/.style={
        sidebyside align=top,
        sidebyside gap=15pt,
        frame hidden,
        halign=flush left,
        size=minimal,
        skin=enhanced jigsaw,
        opacityback=0
    }
}

